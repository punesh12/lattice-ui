{
  "name": "lattice-ui",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/punesh12/lattice-ui.git"
  },
  "homepage": "https://github.com/punesh12/lattice-ui#readme",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:watch": "pnpm --filter @punesh12/lattice-ui test:watch",
    "test:ui": "pnpm --filter @punesh12/lattice-ui test",
    "lint:eslint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev:showcase": "pnpm --filter @punesh12/lattice-showcase dev",
    "storybook": "pnpm --filter @punesh12/lattice-ui storybook",
    "build-storybook": "pnpm --filter @punesh12/lattice-ui build-storybook",
    "publish:tokens": "pnpm --filter @punesh12/lattice-ui-tokens publish --access public --no-git-checks",
    "publish:ui": "pnpm --filter @punesh12/lattice-ui publish --access public --no-git-checks",
    "publish:packages": "pnpm publish:tokens && pnpm publish:ui"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.0.1",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript-eslint": "^8.19.0"
  },
  "packageManager": "pnpm@9.15.0"
}
